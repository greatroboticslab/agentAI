# API keys
.roboflow_key

# Data & outputs (downloadable/regenerable)
downloads/
llm_labeled/
images/

# SLURM logs
slurm_*.out
slurm_*.err

# Model weights (large files)
*.pt

# Allow fine-tuned models we want to track
!weed_llm_benchmark/models/*.pt

# Results - ignore raw detection JSONs but keep evaluation results
weed_llm_benchmark/results/yolo_*.json
weed_llm_benchmark/results/eval_*.json
!weed_llm_benchmark/results/yolo_finetuned_*.json

# Training runs
runs/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db

# multagent - exclude generated/vendored/large files
multagent/metagpt/
multagent/logs/
multagent/workspace/
multagent/.pytest_cache/
multagent/dashboard/frontend/node_modules/
multagent/dashboard/frontend/dist/

# IDE
.idea/
*.iml
